    ],
    "validation_rules": [
      "邮箱格式必须合法",
      "密码长度至少8位",
      "线索状态只能是new/interested/contacted/invalid",
      "用户角色只能是salesperson/admin",
      "分页参数page和limit必须为正整数，limit最大100",
      "搜索关键词不能为空，长度不超过200字符"
    ]
  },
  "tech_stack": {
    "frontend": [
      "React 18",
      "TypeScript 5",
      "Tailwind CSS 3",
      "React Router 6",
      "Axios",
      "React Query"
    ],
    "backend": [
      "Python 3.11",
      "FastAPI",
      "SQLAlchemy",
      "Pydantic",
      "JWT (python-jose)",
      "bcrypt",
      "httpx",
      "OpenAI API"
    ],
    "database": "PostgreSQL 15",
    "infrastructure": [
      "Docker",
      "Docker Compose",
      "Nginx (反向代理)"
    ]
  },
  "mvp_scope": {
    "included_features": [
      "用户注册和登录（邮箱+密码）",
      "JWT令牌认证",
      "销售人员和管理员两种角色",
      "基于关键词的线索搜索（使用第三方API如Clearbit）",
      "AI跟进建议生成（使用OpenAI GPT）",
      "线索列表查看、筛选（按行业、状态）、分页",
      "线索状态标记（感兴趣/已联系/无效）",
      "批量更新线索状态",
      "导出线索为CSV",
      "管理员用户管理（查看、启用/禁用）",
      "管理员查看使用统计（搜索次数、线索数、活跃用户）",
      "管理员配置（API密钥、每日搜索限制）",
      "响应式前端UI",
      "Docker容器化部署"
    ],
    "excluded_features": [
      "社交登录（Google/GitHub等）",
      "邮箱验证",
      "多语言支持",
      "审计日志",
      "实时通知",
      "高级搜索（布尔运算符、模糊匹配）",
      "线索评分或优先级排序",
      "团队协作功能",
      "第三方集成（CRM同步等）",
      "自定义导出字段选择",
      "API限流和请求队列（Phase 2）",
      "缓存层（Redis）"
    ],
    "max_endpoints": 15,
    "max_data_models": 4
  },
  "components": [
    {
      "name": "前端应用（React SPA）",
      "responsibility": "提供用户界面，处理用户交互，通过REST API与后端通信",
      "interfaces": [
        "登录/注册页面",
        "仪表板",
        "线索列表页",
        "线索详情页",
        "管理员页面"
      ],
      "dependencies": [
        "后端API"
      ]
    },
    {
      "name": "后端API服务（FastAPI）",
      "responsibility": "处理所有业务逻辑，提供RESTful API，管理认证、搜索、AI建议、数据持久化",
      "interfaces": [
        "认证API",
        "线索搜索API",
        "AI建议API",
        "线索管理API",
        "管理员API"
      ],
      "dependencies": [
        "PostgreSQL数据库",
        "第三方搜索API（Clearbit）",
        "OpenAI API"
      ]
    },
    {
      "name": "PostgreSQL数据库",
      "responsibility": "持久化存储用户、线索、搜索历史、系统配置数据",
      "interfaces": [
        "SQL查询接口"
      ],
      "dependencies": []
    },
    {
      "name": "第三方搜索服务（Clearbit）",
      "responsibility": "根据关键词搜索潜在客户信息",
      "interfaces": [
        "REST API"
      ],
      "dependencies": []
    },
    {
      "name": "AI建议服务（OpenAI GPT）",
      "responsibility": "根据线索信息生成个性化跟进策略和开场白模板",
      "interfaces": [
        "REST API"
      ],
      "dependencies": []
    },
    {
      "name": "Docker编排（Docker Compose）",
      "responsibility": "容器化部署前端、后端、数据库，管理网络和卷",
      "interfaces": [
        "docker-compose.yml"
      ],
      "dependencies": [
        "前端应用",
        "后端API服务",
        "PostgreSQL数据库"
      ]
    }
  ],
  "frontend_backend_separation": {
    "communication": "REST API only",
    "shared_schema_location": "shared/types.ts (前端) / models.py (后端)",
    "frontend_states": [
      "loading",
      "empty",
      "error",
      "success"
    ],
    "backend_error_codes": [
      "VALIDATION_ERROR",
      "NOT_FOUND",
      "UNAUTHORIZED",
      "FORBIDDEN",
      "INTERNAL_ERROR",
      "RATE_LIMIT_EXCEEDED"
    ]
  },
  "design_decisions": [
    {
      "decision": "采用单体后端架构而非微服务",
      "rationale": "MVP阶段功能简单，单体架构开发速度快，部署简单，无需微服务带来的复杂性",
      "alternatives": [
        "微服务架构"
      ]
    },
    {
      "decision": "使用PostgreSQL而非MongoDB",
      "rationale": "数据关系明确（用户-线索-搜索历史），需要事务支持和复杂查询，PostgreSQL更合适",
      "alternatives": [
        "MongoDB",
        "MySQL"
      ]
    },
    {
      "decision": "使用JWT令牌认证而非Session",
      "rationale": "前后端分离架构中JWT更简单，无需服务端存储会话状态，适合REST API",
      "alternatives": [
        "Session + Cookie",
        "OAuth2"
      ]
    },
    {
      "decision": "AI建议使用OpenAI GPT API",
      "rationale": "OpenAI GPT提供高质量的文本生成能力，适合生成个性化跟进建议，API成熟且易于集成",
      "alternatives": [
        "本地LLM模型",
        "其他LLM API（如Claude）"
      ]
    },
    {
      "decision": "线索搜索使用Clearbit API",
      "rationale": "Clearbit提供丰富的公司和个人数据，API简单易用，适合MVP快速实现",
      "alternatives": [
        "Hunter.io",
        "内部爬虫",
        "其他数据API"
      ]
    },
    {
      "decision": "前端使用React Query管理服务端状态",
      "rationale": "React Query简化了数据获取、缓存和同步，减少样板代码，提升用户体验",
      "alternatives": [
        "Redux",
        "SWR",
        "Context API"
      ]
    }
  ],
  "security_considerations": [
    "密码使用bcrypt加密存储",
    "JWT令牌设置过期时间（默认24小时）",
    "所有API端点（除注册/登录外）需要JWT认证",
    "使用HTTPS传输（生产环境）",
    "输入验证和清理防止SQL注入和XSS攻击",
    "管理员端点需要角色验证（仅admin角色可访问）",
    "用户只能访问自己的线索数据（数据隔离）",
    "API密钥存储在服务端环境变量中，不暴露给前端",
    "搜索限制防止滥用（默认每天100次，管理员可配置）",
    "CORS配置仅允许前端域名访问"
  ],
  "deployment_architecture": "使用Docker Compose进行本地或服务器部署。三个服务：前端（Nginx + React静态文件）、后端（Python FastAPI + Uvicorn）、数据库（PostgreSQL）。Nginx作为反向代理，将/api请求转发到后端，其他请求服务前端静态文件。数据持久化使用Docker卷。环境变量通过.env文件配置。"
}