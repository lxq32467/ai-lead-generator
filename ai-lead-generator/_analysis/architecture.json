{
  "architecture_overview": "AI智能线索生成器v1.0 MVP采用前后端分离的单体架构（Monolithic），前端为React+TypeScript+Tailwind CSS构建的单页应用，后端为Python FastAPI单体服务，PostgreSQL作为主数据库，Docker容器化部署。系统分为用户认证、线索搜索、AI建议生成、线索管理和管理员五大模块，通过RESTful API进行前后端通信。所有业务逻辑集中在后端，前端仅负责UI渲染和用户交互。",
  "lead_schema": {
    "schema_version": "1.0.0",
    "shared_types": {
      "User": {
        "id": "string",
        "email": "string",
        "name": "string",
        "role": "string",
        "is_active": "boolean",
        "created_at": "string"
      },
      "Pagination": {
        "page": "int",
        "limit": "int",
        "total": "int"
      },
      "ApiResponse": {
        "success": "boolean",
        "message": "string",
        "data": "object"
      }
    },
    "data_models": [
      {
        "name": "User",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true,
            "description": "用户唯一标识（UUID）"
          },
          {
            "name": "email",
            "type": "string",
            "required": true,
            "description": "用户邮箱，用于登录"
          },
          {
            "name": "name",
            "type": "string",
            "required": true,
            "description": "用户显示名称"
          },
          {
            "name": "password_hash",
            "type": "string",
            "required": true,
            "description": "bcrypt加密后的密码哈希"
          },
          {
            "name": "role",
            "type": "string",
            "required": true,
            "description": "用户角色：salesperson或admin"
          },
          {
            "name": "is_active",
            "type": "boolean",
            "required": true,
            "description": "账户是否激活"
          },
          {
            "name": "created_at",
            "type": "string",
            "required": true,
            "description": "创建时间（ISO 8601）"
          },
          {
            "name": "updated_at",
            "type": "string",
            "required": true,
            "description": "更新时间（ISO 8601）"
          }
        ],
        "relationships": [
          {
            "type": "has_many",
            "target": "Lead",
            "via": "user_id"
          },
          {
            "type": "has_many",
            "target": "SearchHistory",
            "via": "user_id"
          }
        ]
      },
      {
        "name": "Lead",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true,
            "description": "线索唯一标识（UUID）"
          },
          {
            "name": "user_id",
            "type": "string",
            "required": true,
            "description": "所属用户ID"
          },
          {
            "name": "company_name",
            "type": "string",
            "required": true,
            "description": "公司名称"
          },
          {
            "name": "industry",
            "type": "string",
            "required": true,
            "description": "所属行业"
          },
          {
            "name": "contact_name",
            "type": "string",
            "required": false,
            "description": "联系人姓名"
          },
          {
            "name": "contact_email",
            "type": "string",
            "required": false,
            "description": "联系人邮箱"
          },
          {
            "name": "contact_phone",
            "type": "string",
            "required": false,
            "description": "联系人电话"
          },
          {
            "name": "source",
            "type": "string",
            "required": true,
