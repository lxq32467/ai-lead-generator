            "type": "string",
            "required": true,
            "description": "搜索历史唯一标识（UUID）"
          },
          {
            "name": "user_id",
            "type": "string",
            "required": true,
            "description": "执行搜索的用户ID"
          },
          {
            "name": "keyword",
            "type": "string",
            "required": true,
            "description": "搜索关键词"
          },
          {
            "name": "result_count",
            "type": "int",
            "required": true,
            "description": "返回的线索数量"
          },
          {
            "name": "created_at",
            "type": "string",
            "required": true,
            "description": "搜索时间（ISO 8601）"
          }
        ],
        "relationships": [
          {
            "type": "belongs_to",
            "target": "User",
            "via": "user_id"
          }
