# AI Lead Generator v2.0 — Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_ENV=production
APP_NAME=AI Lead Generator
APP_VERSION=2.0.0

# Database
DATABASE_URL=sqlite:///./data/leadgen.db

# DeepSeek API (required for AI lead generation)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CORS (comma-separated origins, use * for development)
CORS_ORIGINS=*

# Rate Limits
DEFAULT_SEARCH_LIMIT=20

# Stripe (optional — for payment processing)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Server
HOST=0.0.0.0
PORT=8000
