# AI Lead Generator v2.0 — Environment Variables
# Copy this file to .env and fill in your values

# Database (default: SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./leadgen.db
# DATABASE_URL=postgresql://user:password@localhost:5432/leadgen

# DeepSeek API (required for AI lead generation)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Application
APP_ENV=production
CORS_ORIGINS=*
PORT=8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Stripe (for payment processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_monthly

# Plans
FREE_DAILY_LIMIT=10
PRO_DAILY_LIMIT=200
